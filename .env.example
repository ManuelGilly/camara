# --- Signaling (Upstash Redis) ---
# Si están definidas, el signaling usa Upstash Redis.
# Si no, cae a un store en memoria (solo válido para `next dev` local).
# Crear desde Vercel: Storage → Marketplace → Upstash Redis (autoprovisiona ambas).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- TURN ---
# /api/turn elige el primer proveedor disponible. STUN se concatena siempre al final.
# Orden: Cloudflare → Metered → Open Relay público → STUN.

# Opción A — Cloudflare Realtime (1 TB/mes, requiere cuenta Cloudflare)
# https://dash.cloudflare.com → Realtime → TURN → Create TURN App
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_API_TOKEN=

# Opción B — Metered.ca (50 GB/mes, sin tarjeta, solo email)
# https://www.metered.ca/ → Sign up → Dashboard → Settings
# METERED_DOMAIN es el subdominio que te asignan (ej. tu-app.metered.live)
# La API Key sale del mismo dashboard.
METERED_API_KEY=
METERED_DOMAIN=

# Opción C — Open Relay Project (público, sin registro)
# Solo para arrancar/dev. Compartido y rate-limited.
# Activar poniendo a "1".
USE_OPEN_RELAY=
